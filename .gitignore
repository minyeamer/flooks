# Baseline inspired by GitHub's Python and Node templates,
# with path-specific rules for the FLooks monorepo.

# Secrets and local environment
.env
.env.*
!.env.example
.envrc
.direnv/
*.pem
*.key
*.crt
*.p12
*.pfx

# OS and editor artifacts
.DS_Store
.idea/
*.swp
*.swo
*~

# Logs and runtime artifacts
*.log
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Frontend / Node.js
/node_modules/
/apps/*/node_modules/
/packages/*/node_modules/
/apps/web/dist/
/apps/web/.vite/
/apps/web/coverage/
/packages/*/dist/
/coverage/
*.tsbuildinfo

# Backend / Python
.venv/
venv/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.eggs/
*.egg-info/
pip-wheel-metadata/
.python-version
__pypackages__/
.ipynb_checkpoints/

# Build and temporary directories
build/
site/
tmp/
temp/
.cache/
